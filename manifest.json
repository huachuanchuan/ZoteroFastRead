{
  "manifest_version": 2,
  "name": "fastRead",
  "version": "0.1.4",
  "description": "Moonlight-style split-view PDF translation with coordinate-mapped hover highlights for Zotero 7.",
  "icons": {
    "32": "bg.svg",
    "48": "bg.svg",
    "96": "bg.svg"
  },
  "applications": {
    "zotero": {
      "id": "fastread@example.com",
      "update_url": "https://example.com/fastread/updates.json",
      "strict_min_version": "7.0",
      "strict_max_version": "7.1.*"
    }
  }
}
